---
import ExperienceItem from "./ExperienceItem.astro"
const EXPERIENCE = [
  {
    date: "Actualmente...",
    title: "Programador web",
    company: "Versus e Learning",
    description:
      "Participo en el desarrollo de aplicaciones web cubriendo distintas capas del producto: interfaz, backend, APIs, persistencia e integraciones. También puedo involucrarme en la parte de despliegue y configuración técnica cuando hace falta llevar la aplicación a producción.",
